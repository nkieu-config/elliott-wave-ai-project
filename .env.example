# Ollama Cloud API key — get one at https://ollama.com/settings/keys
# Required only for AI Reading + Ask (chart / scoring / KPI work without it).
OLLAMA_API_KEY=

OLLAMA_PRIMARY_MODEL=
OLLAMA_FALLBACK_MODEL=

# Cloud calls in flight at once. Defaults to 1, which serializes the four AI Reading
# lenses — safe for a free-tier rate limit, but a cold reading then costs ~4x one lens.
OLLAMA_CLOUD_CONCURRENCY=

# Set to 1 to enable the "Ask" theory Q&A (needs `uv sync --extra api --extra grounding`).
ANALYST_QA=0
